# =============================================================
# Pluto Dashboard — frontend environment
# =============================================================
# Copy this file to `.env` (or `.env.local`) and fill in the values
# from your running Pluto backend.
#
# Without these vars the dashboard boots against the built-in mock
# client. With them set, every page — Auth, REST, Storage, Realtime,
# Edge Functions — talks to the real backend.

# Base URL of your Pluto backend (no trailing slash).
#   Local dev:  http://localhost:8080
#   Cloud:      https://api.timescard.cloud
VITE_PLUTO_URL=https://api.timescard.cloud

# Publishable anon key from `backend/.env` (ANON_KEY).
# Safe to ship in the browser bundle.
VITE_PLUTO_ANON_KEY=pk_anon_8439f8cb55a8be5f9559105c55401a4f26ab5667e8364718

# OPTIONAL — service_role key for admin-only surfaces (migrations,
# job tokens, edge deploy, audit). Prefer entering this at runtime
# via the Settings page instead of baking it into the bundle in
# any deployment that is exposed publicly.
# VITE_PLUTO_SERVICE_KEY=sk_service_ab628e6d4aed7c347cd0e7e30b9635b65bcc6bc13c5f10f4
