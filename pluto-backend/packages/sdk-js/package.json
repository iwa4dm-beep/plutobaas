{
  "name": "@pluto/js",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript client for Pluto BaaS — Supabase-compatible surface.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --minify",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch"
  },
  "keywords": ["pluto", "baas", "supabase-alternative", "postgres", "auth", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
