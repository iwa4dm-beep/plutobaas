# --- Core ---
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# --- Database ---
DATABASE_URL=postgres://pluto:CHANGE_ME_STRONG_PW@postgres:5432/pluto

# --- Auth / JWT ---
# 64+ char random. Generate: openssl rand -hex 48
PLUTO_JWT_SECRET=CHANGE_ME_TO_A_64_CHAR_RANDOM_STRING_________________________
JWT_ISSUER=https://api.your-domain.com
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=2592000

# --- Storage (MinIO / S3) ---
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME_STRONG
S3_BUCKET=pluto

# --- Redis (rate-limit, realtime pub/sub) ---
REDIS_URL=redis://redis:6379

# --- CORS ---
CORS_ORIGINS=*

# --- Request limits ---
BODY_LIMIT_MB=100
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_AUTH=10

# --- Optional: SMTP for auth emails ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@your-domain.com

# --- Superadmin bootstrap ---
# Any user with this email gets is_superadmin=true on API boot.
PLUTO_ROOT_EMAIL=admin@your-domain.com

# --- Site URL (used in email links) ---
SITE_URL=https://your-frontend.com

# --- Metrics ---
# Scrape /metrics from Prometheus; expose behind auth in production.

# --- Phase 10: Backups ---
# Directory for pg_dump artifacts (mount a durable volume in prod).
PLUTO_BACKUP_DIR=/var/lib/pluto/backups
