# Copy to .env and fill in real values before `docker compose ... up -d`.
# Generate strong secrets with:  openssl rand -hex 32

DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

POSTGRES_PASSWORD=change-me-strong

# HMAC secret for JWT access tokens (min 32 chars).
JWT_SECRET=change-me-with-openssl-rand-hex-32

# Frontend-safe key. Frontends send this as the `apikey` header.
ANON_KEY=pk_anon_change_me

# Server-only key. NEVER expose to the browser. Used by the admin dashboard
# and any trusted backend that needs to bypass RLS.
SERVICE_ROLE_KEY=sk_service_change_me

# Storage: `local` (writes to a docker volume) or `s3` (recommended in prod).
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me-minio-password
S3_BUCKET=pluto
S3_REGION=us-east-1

# Outgoing email. In dev, mailpit runs at smtp://mailpit:1025.
SMTP_URL=smtp://user:pass@smtp.example.com:587

# OAuth providers (optional). Set the redirect URI in each provider's
# console to: https://<DOMAIN>/auth/v1/oauth/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Rate limiting (see docs/api/rate-limits.md for tuning guidance).
# Two independent leaky buckets protect every request: per-IP and
# per-token. Leave commented to use the safe defaults.
# PLUTO_RL_IP_CAPACITY=60
# PLUTO_RL_IP_REFILL=1
# PLUTO_RL_TOKEN_CAPACITY=600
# PLUTO_RL_TOKEN_REFILL=10
# PLUTO_RL_STRICT_IP_CAPACITY=20
# PLUTO_RL_STRICT_IP_REFILL=0.3
# PLUTO_RL_STRICT_TOK_CAPACITY=60
# PLUTO_RL_STRICT_TOK_REFILL=1
