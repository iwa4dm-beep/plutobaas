# Pluto — LOCAL development template
# Copy to `.env` in the backend/ directory, then run:
#   ./scripts/deploy-local.sh
#
# Everything here is safe defaults for a laptop. DO NOT ship to prod.

NODE_ENV=development
PORT=8787

# Postgres (docker-compose brings this up on localhost:54329)
POSTGRES_USER=pluto
POSTGRES_PASSWORD=pluto-dev
POSTGRES_DB=pluto
DATABASE_URL=postgres://pluto:pluto-dev@postgres:5432/pluto

# JWT + API keys — dev-only, regenerate for prod with ./scripts/gen-secrets.sh
JWT_SECRET=dev-jwt-secret-change-me-min-32-chars-xxxxxxxxxxx
ANON_KEY=pk_anon_dev_local
SERVICE_ROLE_KEY=sk_service_dev_local

# Storage — local disk driver writes to ./data/storage
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=/var/lib/pluto/storage
STORAGE_PUBLIC_URL=http://localhost:8787/storage/v1

# SMTP — mailpit UI at http://localhost:8025
SMTP_URL=smtp://mailpit:1025

# OAuth (leave blank in dev unless you're testing the flow)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS — permissive in dev
CORS_ORIGIN=*
