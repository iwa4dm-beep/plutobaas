# Pluto — CLOUD / VPS production template
# Copy to `.env` on the server, then run:
#   ./scripts/deploy-cloud.sh
#
# Generate every secret with:  ./scripts/gen-secrets.sh
# NEVER commit real values.

NODE_ENV=production
PORT=8787

# Public hostname (Caddy uses this for automatic HTTPS via Let's Encrypt)
DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

# Postgres — internal only, not exposed to the host
POSTGRES_USER=pluto
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_32
POSTGRES_DB=pluto
DATABASE_URL=postgres://pluto:REPLACE_WITH_openssl_rand_hex_32@postgres:5432/pluto

# JWT signing (min 32 chars). Rotating this invalidates all sessions.
JWT_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Frontend-safe key (sent as `apikey` header by browser clients)
ANON_KEY=pk_anon_REPLACE

# Server-only key. NEVER expose to the browser.
SERVICE_ROLE_KEY=sk_service_REPLACE

# Storage — S3 / MinIO in prod
STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=REPLACE
S3_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_32
S3_BUCKET=pluto
S3_REGION=us-east-1
STORAGE_PUBLIC_URL=https://api.example.com/storage/v1

# Transactional email
SMTP_URL=smtp://user:pass@smtp.example.com:587

# OAuth (optional). Redirect URI:
#   https://<DOMAIN>/auth/v1/oauth/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Backups — where scripts/backup.sh writes .sql.gz dumps
BACKUP_DIR=/var/backups/pluto
BACKUP_RETENTION_DAYS=14
