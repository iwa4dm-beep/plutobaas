# ─────────────────────────────────────────────────────────────
# Lovable frontend → backend-joy (Pluto API) connection
# Copy to `.env` in your Lovable project root.
# ─────────────────────────────────────────────────────────────

# Public API base URL of your backend-joy deployment.
#  - Cloud VPS:   https://api.timescard.cloud
#  - Local dev:   http://localhost:3000
VITE_PLUTO_URL=https://api.timescard.cloud

# Publishable "anon" key minted from the dashboard:
#   Dashboard → Projects → <your project> → Keys → anon (publishable)
# Safe to commit — RLS on the server enforces access.
VITE_PLUTO_ANON_KEY=pk_anon_replace_me

# Optional: Storage bucket used by upload-example.tsx
VITE_PLUTO_UPLOAD_BUCKET=uploads

# ── OAuth redirect URLs to whitelist in the dashboard ──
# Auth → Redirect URLs → add:
#   https://<your-lovable-app>.lovable.app/auth/callback
#   http://localhost:8080/auth/callback
